<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tabla de Logros - Sistema de Achievements</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            min-height: 100vh;
            color: #fff;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .header {
            text-align: center;
            margin-bottom: 40px;
            padding: 30px;
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid #00d9ff;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0, 217, 255, 0.3);
        }

        .header h1 {
            font-size: 2.8em;
            margin-bottom: 10px;
            color: #00d9ff;
            text-shadow: 0 0 10px rgba(0, 217, 255, 0.5);
            letter-spacing: 2px;
        }

        .header p {
            color: #aaa;
            font-size: 1.1em;
            margin-bottom: 20px;
        }

        .coins-display {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            font-size: 1.5em;
            margin-top: 15px;
        }

        .coins-icon {
            font-size: 2.5em;
            animation: bounce 1s infinite;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }

        @keyframes jumpUnlock {
            0% { transform: scale(0.8) translateY(0); }
            50% { transform: scale(1.1) translateY(-20px); }
            100% { transform: scale(1) translateY(0); }
        }

        @keyframes floatUp {
            0% { 
                opacity: 1;
                transform: translateY(0) translateX(0) scale(1);
            }
            100% { 
                opacity: 0;
                transform: translateY(-100px) translateX(var(--tx)) scale(0.5);
            }
        }

        .celebration-emoji {
            position: fixed;
            font-size: 2.5em;
            pointer-events: none;
            z-index: 1000;
            --tx: 0px;
        }

        .image-container.unlocking {
            animation: jumpUnlock 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .coins-count {
            color: #ffd700;
            font-weight: bold;
            font-size: 1.3em;
        }

        .progress-bar {
            width: 100%;
            height: 10px;
            background: rgba(0, 217, 255, 0.1);
            border-radius: 5px;
            margin-top: 20px;
            overflow: hidden;
            border: 1px solid rgba(0, 217, 255, 0.3);
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #00d9ff 0%, #ffd700 100%);
            transition: width 0.5s ease;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0, 217, 255, 0.5);
        }

        .achievements-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            margin-bottom: 40px;
        }

        .achievement-card {
            background: linear-gradient(135deg, rgba(0, 217, 255, 0.08) 0%, rgba(255, 51, 153, 0.08) 100%);
            border: 2px solid rgba(0, 217, 255, 0.3);
            border-radius: 12px;
            padding: 25px;
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .achievement-card::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle, rgba(0, 217, 255, 0.1) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .achievement-card:hover {
            transform: translateY(-8px);
            border-color: #00d9ff;
            box-shadow: 0 15px 40px rgba(0, 217, 255, 0.2);
        }

        .achievement-card:hover::before {
            opacity: 1;
        }

        .achievement-card.unlocked {
            background: linear-gradient(135deg, rgba(255, 215, 0, 0.1) 0%, rgba(0, 217, 255, 0.1) 100%);
            border-color: #ffd700;
            box-shadow: 0 0 15px rgba(255, 215, 0, 0.2);
        }

        .achievement-card.locked {
            opacity: 0.65;
        }

        .achievement-card.hidden-achievement {
            opacity: 0.5;
            border-color: rgba(255, 51, 153, 0.5);
            background: linear-gradient(135deg, rgba(255, 51, 153, 0.05) 0%, rgba(0, 0, 0, 0.1) 100%);
        }

        .achievement-card.hidden-achievement:hover {
            border-color: rgba(255, 51, 153, 0.8);
            box-shadow: 0 0 20px rgba(255, 51, 153, 0.3);
        }

        .hidden-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            gap: 15px;
            color: rgba(255, 51, 153, 0.7);
        }

        .hidden-icon {
            font-size: 3em;
            animation: pulse 2s ease-in-out infinite;
        }

        .hidden-text {
            font-size: 1.5em;
            font-weight: bold;
            letter-spacing: 3px;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 0.7; }
            50% { transform: scale(1.1); opacity: 1; }
        }

        .image-container {
            width: 100%;
            height: 180px;
            background: rgba(0, 0, 0, 0.4);
            border: 2px dashed rgba(0, 217, 255, 0.5);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 18px;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .achievement-card:hover .image-container {
            border-color: #00d9ff;
            background: rgba(0, 217, 255, 0.05);
        }

        .image-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 8px;
        }

        .image-container.no-image {
            color: rgba(0, 217, 255, 0.6);
            font-size: 13px;
            text-align: center;
            padding: 20px;
            flex-direction: column;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .image-container.no-image::before {
            content: '🖼️';
            font-size: 2.5em;
        }

        .image-input-wrapper {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            opacity: 0;
            cursor: pointer;
            z-index: 10;
        }

        .achievement-header {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 12px;
        }

        .achievement-icon {
            font-size: 1.8em;
            flex-shrink: 0;
        }

        .achievement-title {
            font-size: 1.3em;
            font-weight: 700;
            margin-bottom: 6px;
            color: #00d9ff;
            word-break: break-word;
            line-height: 1.3;
        }

        .achievement-title.editable {
            cursor: text;
            padding: 4px 8px;
            border-radius: 4px;
            transition: all 0.2s ease;
        }

        .achievement-title.editable:hover {
            background: rgba(0, 217, 255, 0.15);
        }

        .achievement-desc {
            font-size: 0.95em;
            color: #bbb;
            margin-bottom: 15px;
            line-height: 1.5;
            word-break: break-word;
        }

        .achievement-desc.editable {
            cursor: text;
            padding: 4px 8px;
            border-radius: 4px;
            transition: all 0.2s ease;
        }

        .achievement-desc.editable:hover {
            background: rgba(0, 217, 255, 0.15);
        }

        .achievement-stats {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 18px;
            padding-top: 18px;
            border-top: 1px solid rgba(0, 217, 255, 0.2);
        }

        .percentage {
            font-size: 0.9em;
            color: #888;
        }

        .percentage-value {
            color: #00d9ff;
            font-weight: 700;
            font-size: 1.05em;
        }

        .checkbox-container {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .checkbox {
            width: 26px;
            height: 26px;
            accent-color: #ffd700;
            cursor: pointer;
            transform: scale(1.4);
            transition: transform 0.2s ease;
        }

        .checkbox:hover {
            transform: scale(1.5);
        }

        .checkbox:checked {
            filter: drop-shadow(0 0 4px #ffd700);
        }

        .coins-reward {
            font-size: 0.95em;
            font-weight: 700;
            color: #ffd700;
            display: flex;
            align-items: center;
            gap: 6px;
            background: rgba(255, 215, 0, 0.1);
            padding: 6px 12px;
            border-radius: 20px;
            border: 1px solid rgba(255, 215, 0, 0.3);
        }

        .locked-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3.5em;
            pointer-events: none;
            border-radius: 8px;
        }

        .achievement-card.unlocked .locked-overlay {
            display: none;
        }

        input[type="text"] {
            width: 100%;
            background: rgba(0, 217, 255, 0.12);
            border: 1.5px solid rgba(0, 217, 255, 0.6);
            color: #00d9ff;
            padding: 10px 12px;
            border-radius: 6px;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: inherit;
            transition: all 0.2s ease;
        }

        input[type="text"]:focus {
            outline: none;
            border-color: #00d9ff;
            box-shadow: 0 0 12px rgba(0, 217, 255, 0.4);
            background: rgba(0, 217, 255, 0.18);
        }

        input[type="file"] {
            cursor: pointer;
        }

        .button-group {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-top: 40px;
            flex-wrap: wrap;
        }

        .reset-btn, .export-btn {
            padding: 12px 35px;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1em;
            font-weight: 700;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .reset-btn {
            background: linear-gradient(135deg, #ff3393 0%, #ff1466 100%);
            border: 2px solid #ff1466;
        }

        .reset-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 25px rgba(255, 19, 102, 0.4);
        }

        .reset-btn:active {
            transform: scale(0.98);
        }

        .export-btn {
            background: linear-gradient(135deg, #00d9ff 0%, #00a8cc 100%);
            border: 2px solid #00d9ff;
        }

        .export-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 25px rgba(0, 217, 255, 0.4);
        }

        .export-btn:active {
            transform: scale(0.98);
        }

        .stats-footer {
            text-align: center;
            margin-top: 50px;
            padding: 20px;
            color: #888;
            font-size: 0.9em;
            border-top: 1px solid rgba(0, 217, 255, 0.2);
        }

        @media (max-width: 768px) {
            .achievements-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .header h1 {
                font-size: 2em;
            }

            .coins-display {
                font-size: 1.2em;
            }

            .achievement-stats {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }

            .checkbox {
                transform: scale(1.2);
            }

            .checkbox:hover {
                transform: scale(1.3);
            }
        }

        .achievement-card.unlocked .achievement-title {
            color: #ffd700;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🏆 TABLA DE LOGROS</h1>
            <p>Completa los objetivos y gana monedas</p>
            <div class="coins-display">
                <span class="coins-icon">💰</span>
                <span class="coins-count" id="coinsCount">0</span>
                <span>/ 150 monedas</span>
            </div>
            <div class="progress-bar">
                <div class="progress-fill" id="progressFill" style="width: 0%"></div>
            </div>
        </div>

        <div class="achievements-grid" id="achievementsGrid"></div>

        <div class="button-group">
            <button class="export-btn" onclick="exportProgress()">📥 Exportar Progreso</button>
            <button class="reset-btn" onclick="resetAllAchievements()">🔄 Reiniciar Todo</button>
        </div>

        <div class="stats-footer">
            <p>💡 Haz doble clic en el título o descripción para editar • Haz clic en la imagen para cambiarla</p>
        </div>
    </div>

    <script>
        const TOTAL_ACHIEVEMENTS = 15;
        const COINS_PER_ACHIEVEMENT = 10;
        const MAX_COINS = TOTAL_ACHIEVEMENTS * COINS_PER_ACHIEVEMENT; // 150

        const defaultAchievements = [
            { 
                title: "Primer Paso", 
                description: "Completa tu primer objetivo y comienza tu viaje", 
                percentage: 87,
                icon: "🎯",
                hidden: false
            },
            { 
                title: "En Marcha", 
                description: "Logra 3 objetivos en total", 
                percentage: 64,
                icon: "⚡",
                hidden: false
            },
            { 
                title: "Mitad del Camino", 
                description: "Alcanza 6 logros completados", 
                percentage: 45,
                icon: "🌟",
                hidden: false
            },
            { 
                title: "Casi Legendario", 
                description: "Completa 9 de los objetivos", 
                percentage: 23,
                icon: "🔥",
                hidden: false
            },
            { 
                title: "Dominio Absoluto", 
                description: "Completa TODOS los 12 objetivos", 
                percentage: 8,
                icon: "👑",
                hidden: false
            },
            { 
                title: "Coleccionista", 
                description: "Obtén 5 logros diferentes", 
                percentage: 52,
                icon: "🎁",
                hidden: false
            },
            { 
                title: "Perseverancia", 
                description: "Mantén una racha de logros consecutivos", 
                percentage: 31,
                icon: "💪",
                hidden: false
            },
            { 
                title: "Ambición", 
                description: "Alcanza 60 monedas totales", 
                percentage: 42,
                icon: "💎",
                hidden: false
            },
            { 
                title: "Obsesión", 
                description: "Desbloquea 10 logros consecutivos", 
                percentage: 19,
                icon: "🎪",
                hidden: false
            },
            { 
                title: "Leyenda", 
                description: "Completa todos los desafíos extremos", 
                percentage: 5,
                icon: "⭐",
                hidden: false
            },
            { 
                title: "Explorador", 
                description: "Descubre todos los secretos ocultos", 
                percentage: 15,
                icon: "🗺️",
                hidden: false
            },
            { 
                title: "Campeón", 
                description: "Sé el primero en completar TODO", 
                percentage: 2,
                icon: "🥇",
                hidden: false
            },
            { 
                title: "Secreto Cósmico", 
                description: "Descubriste el primer misterio del universo", 
                percentage: 12,
                icon: "🌌",
                hidden: true
            },
            { 
                title: "Cazador de Enigmas", 
                description: "Encontraste un logro que estaba oculto", 
                percentage: 8,
                icon: "🔍",
                hidden: true
            },
            { 
                title: "Maestro Supremo", 
                description: "Desbloqueaste TODOS los logros secretos", 
                percentage: 1,
                icon: "✨",
                hidden: true
            }
        ];

        function initializeAchievements() {
            const saved = localStorage.getItem('achievements');
            if (saved) {
                return JSON.parse(saved);
            } else {
                return defaultAchievements.map(ach => ({
                    ...ach,
                    unlocked: false,
                    image: null,
                    hidden: ach.hidden || false
                }));
            }
        }

        let achievements = initializeAchievements();

        function saveAchievements() {
            localStorage.setItem('achievements', JSON.stringify(achievements));
            updateDisplay();
        }

        function updateDisplay() {
            const grid = document.getElementById('achievementsGrid');
            grid.innerHTML = '';

            achievements.forEach((ach, index) => {
                const card = document.createElement('div');
                const isHiddenAndLocked = ach.hidden && !ach.unlocked;
                card.className = `achievement-card ${ach.unlocked ? 'unlocked' : 'locked'} ${isHiddenAndLocked ? 'hidden-achievement' : ''}`;
                card.id = `achievement-${index}`;
                
                if (isHiddenAndLocked) {
                    card.innerHTML = `
                        <div class="image-container">
                            <div class="hidden-content">
                                <div class="hidden-icon">❓</div>
                                <div class="hidden-text">OCULTO</div>
                            </div>
                            <input type="file" class="image-input-wrapper" accept="image/*" onchange="handleImageUpload(event, ${index})">
                        </div>
                        <div class="locked-overlay">🔐</div>
                        <div class="achievement-header">
                            <div class="achievement-icon">❓</div>
                            <div style="flex: 1;">
                                <div class="achievement-title" style="color: rgba(255, 51, 153, 0.7);">Logro secreto...</div>
                            </div>
                        </div>
                        <div class="achievement-desc" style="color: rgba(255, 51, 153, 0.6); text-align: center;">Desbloquea este logro para ver su contenido</div>
                        <div class="achievement-stats">
                            <div class="percentage">
                                <span class="percentage-value">?</span> lo tienen
                            </div>
                            <div class="checkbox-container">
                                <input type="checkbox" class="checkbox" ${ach.unlocked ? 'checked' : ''} 
                                    onchange="toggleAchievement(${index}, this)">
                                <span class="coins-reward">+${COINS_PER_ACHIEVEMENT}</span>
                            </div>
                        </div>
                    `;
                } else {
                    const imageContainer = ach.image 
                        ? `<div class="image-container"><img src="${ach.image}" alt="${ach.title}"><input type="file" class="image-input-wrapper" accept="image/*" onchange="handleImageUpload(event, ${index})"></div>`
                        : `<div class="image-container no-image">Haz clic para añadir imagen<input type="file" class="image-input-wrapper" accept="image/*" onchange="handleImageUpload(event, ${index})"></div>`;

                    card.innerHTML = `
                        ${imageContainer}
                        ${!ach.unlocked ? '<div class="locked-overlay">🔒</div>' : ''}
                        <div class="achievement-header">
                            <div class="achievement-icon">${ach.icon}</div>
                            <div style="flex: 1;">
                                <div class="achievement-title editable" ondblclick="editTitle(${index}, this)">${ach.title}</div>
                            </div>
                        </div>
                        <div class="achievement-desc editable" ondblclick="editDesc(${index}, this)">${ach.description}</div>
                        <div class="achievement-stats">
                            <div class="percentage">
                                <span class="percentage-value">${ach.percentage}%</span> han desbloqueado esto
                            </div>
                            <div class="checkbox-container">
                                <input type="checkbox" class="checkbox" ${ach.unlocked ? 'checked' : ''} 
                                    onchange="toggleAchievement(${index}, this)">
                                <span class="coins-reward">+${COINS_PER_ACHIEVEMENT}</span>
                            </div>
                        </div>
                    `;
                }
                grid.appendChild(card);
            });

            updateCoinsDisplay();
        }

        function handleImageUpload(event, index) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = (e) => {
                    achievements[index].image = e.target.result;
                    saveAchievements();
                };
                reader.readAsDataURL(file);
            }
        }

        function editTitle(index, element) {
            const currentText = achievements[index].title;
            const input = document.createElement('input');
            input.type = 'text';
            input.value = currentText;
            input.className = 'achievement-title editable';
            
            element.replaceWith(input);
            input.focus();
            input.select();

            function saveEdit() {
                const newText = input.value.trim() || currentText;
                achievements[index].title = newText;
                saveAchievements();
            }

            input.addEventListener('blur', saveEdit);
            input.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') saveEdit();
            });
        }

        function editDesc(index, element) {
            const currentText = achievements[index].description;
            const input = document.createElement('input');
            input.type = 'text';
            input.value = currentText;
            input.className = 'achievement-desc editable';
            
            element.replaceWith(input);
            input.focus();
            input.select();

            function saveEdit() {
                const newText = input.value.trim() || currentText;
                achievements[index].description = newText;
                saveAchievements();
            }

            input.addEventListener('blur', saveEdit);
            input.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') saveEdit();
            });
        }

        function toggleAchievement(index, checkbox) {
            achievements[index].unlocked = checkbox.checked;
            
            if (checkbox.checked) {
                triggerUnlockAnimation(index);
            }
            
            saveAchievements();
        }

        function triggerUnlockAnimation(index) {
            const card = document.getElementById(`achievement-${index}`);
            if (!card) return;

            const imageContainer = card.querySelector('.image-container');
            if (imageContainer) {
                imageContainer.classList.add('unlocking');
                setTimeout(() => {
                    imageContainer.classList.remove('unlocking');
                }, 800);
            }

            // Celebración con emojis
            const emojis = ['🎉', '✨', '🎊', '⭐', '🌟', '💫', '🎈', '🎆'];
            const cardRect = card.getBoundingClientRect();
            const centerX = cardRect.left + cardRect.width / 2;
            const centerY = cardRect.top + cardRect.height / 2;

            for (let i = 0; i < 12; i++) {
                const emoji = document.createElement('div');
                emoji.className = 'celebration-emoji';
                emoji.textContent = emojis[Math.floor(Math.random() * emojis.length)];
                
                const angle = (i / 12) * Math.PI * 2;
                const distance = 80;
                const tx = Math.cos(angle) * distance;
                const ty = Math.sin(angle) * distance;
                
                emoji.style.left = centerX + 'px';
                emoji.style.top = centerY + 'px';
                emoji.style.setProperty('--tx', tx + 'px');
                emoji.style.animation = `floatUp 1s ease-out forwards`;
                emoji.style.animationDelay = (i * 0.05) + 's';
                
                document.body.appendChild(emoji);
                
                setTimeout(() => {
                    emoji.remove();
                }, 1500);
            }

            // Sonido opcional (comentado para no molestar)
            // playUnlockSound();
        }

        function updateCoinsDisplay() {
            const totalCoins = achievements.filter(a => a.unlocked).length * COINS_PER_ACHIEVEMENT;
            document.getElementById('coinsCount').textContent = totalCoins;
            
            const percentage = (totalCoins / MAX_COINS) * 100;
            document.getElementById('progressFill').style.width = percentage + '%';
        }

        function resetAllAchievements() {
            if (confirm('¿Estás seguro de que quieres reiniciar TODOS los logros? Esta acción no se puede deshacer.')) {
                achievements = achievements.map(ach => ({
                    ...ach,
                    unlocked: false
                }));
                saveAchievements();
                alert('✨ ¡Todos los logros han sido reiniciados!');
            }
        }

        function exportProgress() {
            const totalCoins = achievements.filter(a => a.unlocked).length * COINS_PER_ACHIEVEMENT;
            const unlockedCount = achievements.filter(a => a.unlocked).length;
            const dataText = `PROGRESO DE LOGROS\n${'='.repeat(40)}\nMonedas: ${totalCoins}/${MAX_COINS}\nLogros desbloqueados: ${unlockedCount}/${TOTAL_ACHIEVEMENTS}\n\nDetalles:\n`;
            
            const details = achievements.map((ach, i) => 
                `${i + 1}. ${ach.title}: ${ach.unlocked ? '✓ DESBLOQUEADO' : '✗ Bloqueado'}`
            ).join('\n');

            const fullText = dataText + details;
            const blob = new Blob([fullText], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `achievements_progress_${new Date().toISOString().slice(0, 10)}.txt`;
            a.click();
            URL.revokeObjectURL(url);
            alert('✅ Progreso exportado correctamente');
        }

        updateDisplay();
    </script>
</body>
</html>
